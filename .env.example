# Sao chép file này thành .env.local và điền API key thật
# Lấy key miễn phí tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# Model Gemini dùng cho app (free tier). Có thể đổi mà không cần sửa code:
# gemini-2.5-flash (khuyên dùng — gemini-2.0-flash bị giới hạn free tier = 0 với nhiều key mới)
GEMINI_MODEL=gemini-2.5-flash

# Supabase Postgres — lấy ở Project Settings > Database > Connection string
# DATABASE_URL: dùng "Connection pooling" (port 6543, có ?pgbouncer=true) — dùng lúc app chạy
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL: dùng "Direct connection" (port 5432) — chỉ dùng khi chạy `prisma migrate`
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"
