# Sao chép file này thành .env.local và điền API key thật
# Lấy key miễn phí tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# Model Gemini dùng cho app (free tier). Có thể đổi mà không cần sửa code:
# gemini-2.5-flash (khuyên dùng — gemini-2.0-flash bị giới hạn free tier = 0 với nhiều key mới)
GEMINI_MODEL=gemini-2.5-flash
